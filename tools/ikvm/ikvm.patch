+ * JVM_FindLibraryEntry.
+ *
+ * In a normal (non-WASM) build these functions call dlopen()/dlsym() to load
+ * shared libraries at runtime.  Under Emscripten all native code is compiled
+ * into a single WebAssembly binary; true dynamic loading is not available
+ * without -sMAIN_MODULE=1, which is often undesirable.
+ *
+ * This file implements a fully static alternative:
+ *
+ *   JVM_LoadLibrary
+ *     Searches jvm_static_libs[] (populated by the file generated by
+ *     gen-static-libs.py) for an entry whose path matches the requested name.
+ *     On success it returns a pointer to that entry as an opaque, non-NULL
+ *     handle.  On failure it throws java/lang/UnsatisfiedLinkError.
+ *
+ *   JVM_FindLibraryEntry
+ *     Uses the handle returned by JVM_LoadLibrary to index into the matching
+ *     entry's per-library symbol table (also generated by gen-static-libs.py
+ *     from llvm-nm output).  The symbol table stores compile-time function
+ *     pointer addresses so no runtime symbol resolution is required at all.
+ *
+ * Compile alongside jvm.cpp (with the existing JVM_LoadLibrary /
+ * JVM_FindLibraryEntry guarded by #ifndef __EMSCRIPTEN__) and the .c file
+ * produced by gen-static-libs.py.
+ *
+ * Example build fragment (extends build-local.sh step 9):
+ *
+ *   python3 gen-static-libs.py \
+ *       -o "$WORKSPACE/out/native/tmp/jvm_static_libs.c" \
+ *       "libjava.so:$WORKSPACE/out/native/libjava_jni.a" \
+ *       "libzip.so:$WORKSPACE/out/native/libzip_jni.a"
+ *
+ *   emcc -O2 -fPIC -fdeclspec -pthread \
+ *        -I"$LIBJVM_SRC" "${COMMON_DEFS[@]}" "${COMMON_INCLUDES[@]}" \
+ *        -c "$LIBJVM_SRC/jvm_emscripten_dynlib.c" \
+ *        -o "$WORKSPACE/out/native/tmp/jvm_emscripten_dynlib.o"
+ *
+ *   emcc -O2 -fPIC -fdeclspec -pthread \
+ *        -I"$LIBJVM_SRC" \
+ *        -c "$WORKSPACE/out/native/tmp/jvm_static_libs.c" \
+ *        -o "$WORKSPACE/out/native/tmp/jvm_static_libs.o"
+ *
+ *   emar rcs "$WORKSPACE/out/native/libjvm.a" \
+ *       jni.o jni_vargs.o jvm.o \
+ *       jvm_emscripten_dynlib.o jvm_static_libs.o
+ */
+
+#ifdef __EMSCRIPTEN__
+
+#include <jni.h>
+#include <jvm.h>
+#include <string.h>
+#include <stdio.h>
+
+#include "ikvm.h"
+#include "jvm_emscripten_dynlib.h"
+
+/* ── JVM_LoadLibrary ─────────────────────────────────────────────────────── */
+
+void* JNICALL JVM_LoadLibrary(const char* name)
+{
+    int i;
+    for (i = 0; jvm_static_libs[i].path != NULL; i++) {
+        if (strcmp(jvm_static_libs[i].path, name) == 0) {
+            /*
+             * Return a stable, non-NULL pointer to the registry entry.
+             * JVM_FindLibraryEntry receives this value as its handle and uses
+             * it to index into the matching per-library symbol table.
+             */
+            return (void*)&jvm_static_libs[i];
+        }
+    }
+
+    {
+        char msg[1024];
+        snprintf(msg, sizeof msg,
+                 "%s: not found in Emscripten static library registry"
+                 " (add it to the gen-static-libs.py input list)",
+                 name);
+		printf("%s\n", msg);
+        JVM_ThrowException("java/lang/UnsatisfiedLinkError", msg);
+    }
+    return NULL;
+}
+
+/* ── JVM_FindLibraryEntry ────────────────────────────────────────────────── */
+
+void* JNICALL JVM_FindLibraryEntry(void* handle, const char* name)
+{
+    const jvm_static_lib_entry_t *entry = (const jvm_static_lib_entry_t*)handle;
+    int i;
+
+    if (entry == NULL || entry->symbols == NULL)
+        return NULL;
+
+    /*
+     * Linear scan through the per-library symbol table generated by
+     * gen-static-libs.py.  Each ptr was resolved at compile time via an
+     * extern declaration of the actual function, so no runtime lookup is
+     * needed and -sMAIN_MODULE is not required.
+     */
+    for (i = 0; entry->symbols[i].name != NULL; i++) {
+        if (strcmp(entry->symbols[i].name, name) == 0)
+            return entry->symbols[i].ptr;
+    }
+
+    return NULL;
+}
+
+#endif /* __EMSCRIPTEN__ */
diff --git a/src/libjvm/jvm_emscripten_dynlib.h b/src/libjvm/jvm_emscripten_dynlib.h
new file mode 100644
index 000000000..bf98bcd87
--- /dev/null
+++ b/src/libjvm/jvm_emscripten_dynlib.h
@@ -0,0 +1,49 @@
+/*
+ * jvm_emscripten_dynlib.h
+ *
+ * Shared types and declarations for the Emscripten static library registry.
+ * Included by both jvm_emscripten_dynlib.c (the logic) and by the .c file
+ * produced by gen-static-libs.py (the data).
+ */
+
+#ifndef JVM_EMSCRIPTEN_DYNLIB_H
+#define JVM_EMSCRIPTEN_DYNLIB_H
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/*
+ * One symbol entry in a per-library lookup table.
+ * name - the symbol name passed to JVM_FindLibraryEntry (e.g. "Java_Foo_bar")
+ * ptr  - address of the symbol as resolved at compile time via a forward
+ *        declaration in the generated file; stored as void* so that
+ *        JVM_FindLibraryEntry can return it directly to the JNI caller.
+ */
+typedef struct {
+    const char *name;
+    void       *ptr;
+} jvm_symbol_entry_t;
+
+/*
+ * One entry per statically-linked library.
+ * path    - the exact string Java passes to JVM_LoadLibrary (e.g. "libjava.so"
+ *           or the full path Java's launcher resolves to)
+ * symbols - NULL-terminated array of symbol entries for this library,
+ *           generated by gen-static-libs.py from llvm-nm output; NULL if the
+ *           library was registered without an archive (empty symbol table).
+ */
+typedef struct {
+    const char               *path;
+    const jvm_symbol_entry_t *symbols;
+} jvm_static_lib_entry_t;
+
+/* Defined in the file generated by gen-static-libs.py */
+extern const jvm_static_lib_entry_t jvm_static_libs[];
+extern const int jvm_static_libs_count;
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* JVM_EMSCRIPTEN_DYNLIB_H */
