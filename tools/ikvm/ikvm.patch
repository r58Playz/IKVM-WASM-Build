diff --git a/src/IKVM.Runtime/Java/Externs/sun/nio/ch/FileDispatcherImpl.cs b/src/IKVM.Runtime/Java/Externs/sun/nio/ch/FileDispatcherImpl.cs
new file mode 100644
index 000000000..e7436614b
--- /dev/null
+++ b/src/IKVM.Runtime/Java/Externs/sun/nio/ch/FileDispatcherImpl.cs
@@ -0,0 +1,44 @@
+namespace IKVM.Java.Externs.sun.nio.ch
+{
+
+    /// <summary>
+    /// Managed implementation of select <c>sun.nio.ch.FileDispatcherImpl</c> native methods.
+    /// </summary>
+    /// <remarks>
+    /// <para>
+    /// Only <c>force0</c> (the back-end of <see cref="java.nio.channels.FileChannel.force(bool)"/>) is
+    /// intercepted; every other native method falls through to the original libnio implementation, so
+    /// ordinary channel I/O is unaffected.
+    /// </para>
+    /// <para>
+    /// In the WASM build every writable file lives on either the OPFS-backed WasmFS mount (<c>/libsdl</c>)
+    /// or an in-memory MEMFS mount. The stock <c>force0</c> maps to <c>fdatasync</c> -&gt; WasmFS
+    /// <c>__wasi_fd_sync</c> -&gt; <c>OPFSFile::flush</c> -&gt; <c>FileSystemSyncAccessHandle.flush()</c>,
+    /// which forces bytes through to physical storage and is the single most expensive OPFS primitive. It
+    /// is what stalls Minecraft's chunk save/close path (every cached region file is <c>force(true)</c>'d on
+    /// flush and again on close, serialized on the single OPFS proxy thread).
+    /// </para>
+    /// <para>
+    /// The flush is also unnecessary here: OPFS sync-access-handle writes are already durable without an
+    /// explicit <c>flush()</c> (it only forces through to the device, which the browser/OS manage), and
+    /// MEMFS has no backing store at all. So this no-ops the sync and returns success, removing the stall
+    /// with no in-browser durability loss.
+    /// </para>
+    /// </remarks>
+    static class FileDispatcherImpl
+    {
+
+        /// <summary>
+        /// Implements the native method 'force0'. Returns 0 (success) without issuing an fsync/fdatasync.
+        /// </summary>
+        /// <param name="fd">the file descriptor to sync (unused)</param>
+        /// <param name="metaData">whether file metadata should also be synced (unused)</param>
+        /// <returns>0, indicating success</returns>
+        public static int force0(object fd, bool metaData)
+        {
+            return 0;
+        }
+
+    }
+
+}
diff --git a/src/IKVM.Runtime/Java/Externs/sun/nio/fs/UnixNativeDispatcher.cs b/src/IKVM.Runtime/Java/Externs/sun/nio/fs/UnixNativeDispatcher.cs
new file mode 100644
index 000000000..1cca31bbe
--- /dev/null
+++ b/src/IKVM.Runtime/Java/Externs/sun/nio/fs/UnixNativeDispatcher.cs
@@ -0,0 +1,306 @@
+using System;
+using System.Runtime.InteropServices;
+using System.Text;
+
+using IKVM.Runtime;
+using IKVM.Runtime.Accessors.Sun.Nio.Fs;
+using IKVM.Runtime.JNI;
+using IKVM.Runtime.Vfs;
+
+namespace IKVM.Java.Externs.sun.nio.fs
+{
+
+    /// <summary>
+    /// Managed implementations of select <c>sun.nio.fs.UnixNativeDispatcher</c> native methods.
+    /// </summary>
+    /// <remarks>
+    /// <para>
+    /// Paths within the IKVM virtual file system (e.g. <c>/ikvm/assembly/&lt;id&gt;/classes</c>) only exist in the
+    /// managed <see cref="JVM.Vfs"/> table; the underlying (emscripten) file system that backs libnio knows
+    /// nothing about them. <c>java.io.File</c> operations already account for this in
+    /// <see cref="IKVM.Java.Externs.java.io.UnixFileSystem"/>; this class brings the same VFS awareness to the
+    /// <c>java.nio.file</c> stack so that, for example, <c>Path.toRealPath</c> on a VFS path no longer fails with
+    /// <c>NoSuchFileException</c>.
+    /// </para>
+    /// <para>
+    /// Only metadata operations are intercepted: <c>realpath0</c>, <c>stat0</c>/<c>lstat0</c> and <c>access0</c>.
+    /// These cover the common NIO queries (<c>Path.toRealPath</c>, <c>Files.exists</c>/<c>isDirectory</c>/
+    /// <c>size</c>/<c>getLastModifiedTime</c>, <c>Files.isReadable</c>). Content reads (<c>open0</c>) and directory
+    /// enumeration (<c>opendir0</c>/<c>readdir</c>) over VFS paths are deliberately left to native code: a NIO
+    /// open returns an OS file descriptor that is subsequently serviced by native pread/pwrite, which cannot be
+    /// backed by a managed VFS stream without also intercepting the channel/dispatcher layer. Any native method
+    /// not defined here continues to bind directly to libnio.
