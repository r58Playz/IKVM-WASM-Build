+#ifdef __EMSCRIPTEN_PTHREADS__
+static void ffi_wasm_install_closure_proxy(void *arg)
+{
+  ffi_wasm_install_closure_locally((ffi_closure *)arg);
+}
+
+EMSCRIPTEN_KEEPALIVE void ffi_wasm_sync_closure_on_thread_async(int target_thread,
+                                                                int closure_arg)
+{
+  emscripten_proxy_async(emscripten_proxy_get_system_queue(),
+                         (pthread_t)(uintptr_t)target_thread,
+                         ffi_wasm_install_closure_proxy,
+                         (void *)(uintptr_t)closure_arg);
+}
+
+static void ffi_wasm_sync_closure_on_all_threads_from_main(void *arg)
+{
+  ffi_wasm_closure_sync_request *request =
+    (ffi_wasm_closure_sync_request *)arg;
+  int main_thread = (int)(uintptr_t)emscripten_main_runtime_thread_id();
+
+  if (request->skip_thread != main_thread)
+    ffi_wasm_install_closure_locally(request->closure);
+
+  ffi_wasm_sync_closure_on_all_workers_js((int)(uintptr_t)request->closure,
+                                          request->skip_thread);
+}
+
+EMSCRIPTEN_KEEPALIVE void
+ffi_wasm_sync_registered_closures_for_current_thread_export(void)
+{
+  ffi_wasm_closure_node *node;
+
+  pthread_once(&ffi_wasm_closure_state_once, ffi_wasm_init_closure_state);
+  pthread_mutex_lock(&ffi_wasm_closure_lock);
+  for (node = ffi_wasm_closure_list; node != NULL; node = node->next)
+    ffi_wasm_install_closure_locally(node->closure);
+  pthread_mutex_unlock(&ffi_wasm_closure_lock);
+}
+
+__attribute__((constructor))
+static void ffi_wasm_install_pthread_start_hook_ctor(void)
+{
+  ffi_wasm_install_pthread_start_hook();
+}
+#endif
+
+void * __attribute__ ((visibility ("default")))
+ffi_closure_alloc(size_t size, void **code) {
+  ffi_closure *closure = (ffi_closure *)malloc(size);
+  unsigned int index;
+
+  if (closure == NULL)
+    return NULL;
+
+#ifdef __EMSCRIPTEN_PTHREADS__
+  index = ffi_wasm_allocate_closure_slot();
+#else
+  index = ffi_wasm_alloc_table_slot();
+#endif
+
+  *code = (void *)(uintptr_t)index;
+  closure->ftramp = (void *)(uintptr_t)index;
+  return closure;
+}
+
+void __attribute__ ((visibility ("default")))
+ffi_closure_free(void *closure) {
+#ifdef __EMSCRIPTEN_PTHREADS__
+  ffi_wasm_unregister_closure((ffi_closure *)closure);
+#else
+  ffi_wasm_free_table_slot((unsigned int)(uintptr_t)((ffi_closure *)closure)->ftramp);
+#endif
+  free(closure);
+}
