+EM_JS_MACROS(void, ffi_wasm_install_pthread_start_hook, (), {
+  if (typeof Module === 'undefined' || !Module['invokeEntryPoint']) {
+    return;
+  }
+  if (Module['ffiWasmInvokeEntryPointWrapped']) {
+    return;
+  }
+  var original = Module['invokeEntryPoint'];
