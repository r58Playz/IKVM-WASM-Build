+EM_JS_MACROS(void, ffi_wasm_sync_closure_on_all_workers_js, (int closure_arg, int skip_thread_arg), {
+  if (typeof PThread === 'undefined') {
+    return;
+  }
+  for (var ptr in PThread.pthreads) {
+    var thread = Number(ptr);
+    if (thread === skip_thread_arg) {
+      continue;
+    }
+    _ffi_wasm_sync_closure_on_thread_async(thread, closure_arg);
+  }
+})
