+#ifdef __EMSCRIPTEN_PTHREADS__
+typedef struct ffi_wasm_closure_node {
+  ffi_closure *closure;
+  struct ffi_wasm_closure_node *next;
+} ffi_wasm_closure_node;
+
+typedef struct ffi_wasm_closure_sync_request {
+  ffi_closure *closure;
+  int skip_thread;
+} ffi_wasm_closure_sync_request;
+
+static pthread_once_t ffi_wasm_closure_state_once = PTHREAD_ONCE_INIT;
+static pthread_mutex_t ffi_wasm_closure_lock = PTHREAD_MUTEX_INITIALIZER;
+static unsigned int ffi_wasm_next_closure_slot;
+static ffi_wasm_closure_node *ffi_wasm_closure_list;
+
+EM_JS_MACROS(unsigned int, ffi_wasm_get_table_length, (), {
+  return wasmTable.length;
+})
+
+static void ffi_wasm_init_closure_state(void)
+{
+  ffi_wasm_next_closure_slot = ffi_wasm_get_table_length();
+}
+
+static unsigned int ffi_wasm_allocate_closure_slot(void)
+{
+  unsigned int slot;
+
+  pthread_once(&ffi_wasm_closure_state_once, ffi_wasm_init_closure_state);
+  pthread_mutex_lock(&ffi_wasm_closure_lock);
+  slot = ffi_wasm_next_closure_slot++;
+  pthread_mutex_unlock(&ffi_wasm_closure_lock);
+  return slot;
+}
+
+static int ffi_wasm_register_closure(ffi_closure *closure)
+{
+  ffi_wasm_closure_node *node;
+  ffi_wasm_closure_node *cur;
+
+  pthread_once(&ffi_wasm_closure_state_once, ffi_wasm_init_closure_state);
+  node = (ffi_wasm_closure_node *)malloc(sizeof(*node));
+  if (node == NULL)
+    return 0;
+
+  pthread_mutex_lock(&ffi_wasm_closure_lock);
+  for (cur = ffi_wasm_closure_list; cur != NULL; cur = cur->next) {
+    if (cur->closure == closure) {
+      pthread_mutex_unlock(&ffi_wasm_closure_lock);
+      free(node);
+      return 1;
+    }
+  }
+
+  node->closure = closure;
+  node->next = ffi_wasm_closure_list;
+  ffi_wasm_closure_list = node;
+  pthread_mutex_unlock(&ffi_wasm_closure_lock);
+  return 1;
 }
 
+static void ffi_wasm_unregister_closure(ffi_closure *closure)
+{
+  ffi_wasm_closure_node **link;
+  ffi_wasm_closure_node *node;
+
+  pthread_once(&ffi_wasm_closure_state_once, ffi_wasm_init_closure_state);
+  pthread_mutex_lock(&ffi_wasm_closure_lock);
+  for (link = &ffi_wasm_closure_list; *link != NULL; link = &(*link)->next) {
+    if ((*link)->closure != closure)
+      continue;
+
+    node = *link;
+    *link = node->next;
+    pthread_mutex_unlock(&ffi_wasm_closure_lock);
+    free(node);
+    return;
+  }
+  pthread_mutex_unlock(&ffi_wasm_closure_lock);
+}
+#endif
