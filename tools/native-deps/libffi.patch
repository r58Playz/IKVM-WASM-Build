 // EM_JS does not correctly handle function pointer arguments, so we need a
 // helper
 ffi_status ffi_prep_closure_loc(ffi_closure *closure, ffi_cif *cif,
                                 void (*fun)(ffi_cif *, void *, void **, void *),
                                 void *user_data, void *codeloc) {
+	/*
   if (cif->abi != FFI_WASM32_EMSCRIPTEN)
     return FFI_BAD_ABI;
-  return ffi_prep_closure_loc_helper(closure, cif, (void *)fun, user_data,
-                                     codeloc);
+	*/
+  closure->cif = cif;
+  closure->fun = fun;
+  closure->user_data = user_data;
+
+  if (ffi_wasm_install_closure_locally(closure) != FFI_OK)
+    return FFI_BAD_TYPEDEF;
+
+#ifdef __EMSCRIPTEN_PTHREADS__
+  if (!ffi_wasm_register_closure(closure))
+    return FFI_BAD_TYPEDEF;
+
+  {
+    ffi_wasm_closure_sync_request request = {
+      closure,
+      (int)(uintptr_t)pthread_self()
+    };
+    pthread_t main_thread = emscripten_main_runtime_thread_id();
+
+    if (pthread_self() == main_thread)
+      ffi_wasm_sync_closure_on_all_threads_from_main(&request);
+    else
+      emscripten_proxy_sync(emscripten_proxy_get_system_queue(),
+                            main_thread,
+                            ffi_wasm_sync_closure_on_all_threads_from_main,
+                            &request);
+  }
+#endif
+
+  return FFI_OK;
 }
