+static void ng_gl4es_try_initialize(void) {
+    EMSCRIPTEN_WEBGL_CONTEXT_HANDLE context;
+
+    if (g_ng_gl4es_initialized) {
+        return;
+    }
+
+    context = emscripten_webgl_get_current_context();
+    if (context <= 0) {
+        return;
+    }
+
+    set_getprocaddress(emscripten_webgl_get_proc_address);
+    set_getmainfbsize(ng_gl4es_get_mainfb_size);
+    initialize_gl4es();
+    g_ng_gl4es_initialized = 1;
