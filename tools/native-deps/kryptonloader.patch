new file mode 100644
index 0000000..c23345d
--- /dev/null
+++ b/src/gl/krypton_export_names.h
@@ -0,0 +1,29 @@
+/* Krypton Wrapper export-name helper.
+ *
+ * NG-GL4ES defines a handful of GL entry points with bare `glXXX` names
+ * (sync objects, glReadBuffer, glTexBuffer, glVertexAttribI/P*, ...) that
+ * collide with emscripten's stock libGL at the final WASM link step. On
+ * Emscripten we rename those definitions to `krypton_glXXX` at the C-level
+ * so the archive's public surface is conflict-free; gl4es' proc-address
+ * dispatcher still resolves the original names via gl4es_glXXX thunks (see
+ * emscripten_aliases.c).
+ *
+ *   VISIBLE void KW_EXPORT(glReadBuffer)(GLenum src) { ... }
+ *
+ * KW_EXPORT_STR(name) is the stringized form, used in __attribute__((alias))
+ * payloads when an alias has to point at the renamed canonical symbol.
+ */
+
+#ifndef KRYPTON_EXPORT_NAMES_H
+#define KRYPTON_EXPORT_NAMES_H
+
+#ifdef __EMSCRIPTEN__
+#define KW_EXPORT(name)        krypton_##name
+#define KW_EXPORT_STR_(name)   "krypton_" #name
+#define KW_EXPORT_STR(name)    KW_EXPORT_STR_(name)
+#else
+#define KW_EXPORT(name)        name
+#define KW_EXPORT_STR(name)    #name
+#endif
+
+#endif /* KRYPTON_EXPORT_NAMES_H */
