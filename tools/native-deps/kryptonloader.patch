+EXPORT EMSCRIPTEN_WEBGL_CONTEXT_HANDLE
+ng_gl4es_webgl_create_context(const char* target, const EmscriptenWebGLContextAttributes* attributes) {
+    EmscriptenWebGLContextAttributes local_attributes;
+    const char* context_target = target;
+
+    if (attributes) {
+        local_attributes = *attributes;
+    } else {
+        emscripten_webgl_init_context_attributes(&local_attributes);
+    }
+
+	local_attributes.explicitSwapControl = 1;
+	local_attributes.alpha = 0;
+
+    if (target && target[0] != '\0') {
+        strncpy(g_ng_gl4es_canvas_selector, target, sizeof(g_ng_gl4es_canvas_selector) - 1);
+        g_ng_gl4es_canvas_selector[sizeof(g_ng_gl4es_canvas_selector) - 1] = '\0';
+    }
+
+    if (!context_target || context_target[0] == '\0') {
+        context_target = g_ng_gl4es_canvas_selector;
+    }
+
+    return emscripten_webgl_create_context(context_target, &local_attributes);
+}
