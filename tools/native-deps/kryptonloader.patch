+enum {
+    NG_GL_ARRAY_BUFFER = 0x8892u,
+    NG_GL_FRAMEBUFFER = 0x8D40u,
+    NG_GL_RENDERBUFFER = 0x8D41u,
+    NG_GL_TEXTURE_2D = 0x0DE1u,
+    NG_GL_DYNAMIC_DRAW = 0x88E8u,
+    NG_GL_FLOAT = 0x1406u,
+    NG_GL_INVALID_INDEX = 0xFFFFFFFFu,
+};
+
+static void* ng_gl4es_lookup_proc_raw(const char* name) {
+    void* proc = gl4es_GetProcAddress(name);
+    if (!proc) {
+        proc = emscripten_webgl_get_proc_address(name);
+    }
+    return proc;
+}
+
+static void* ng_gl4es_lookup_proc_multi(const char* const* names) {
+    int i = 0;
+
+    while (names[i]) {
+        void* proc = ng_gl4es_lookup_proc_raw(names[i]);
+        if (proc) {
+            return proc;
+        }
+        ++i;
+    }
+
+    return NULL;
+}
+
+static int ng_gl4es_glGetInteger(unsigned int pname) {
+    int value = 0;
+
+    if (!g_glGetIntegerv_shim) {
+        g_glGetIntegerv_shim = (glGetIntegervShimProc)ng_gl4es_lookup_proc_raw("glGetIntegerv");
+    }
+
+    if (g_glGetIntegerv_shim) {
+        g_glGetIntegerv_shim(pname, &value);
+    }
+
+    return value;
+}
+
+static int ng_gl4es_glGetProgrami(unsigned int program, unsigned int pname) {
+    int value = 0;
+
+    if (!g_glGetProgramiv_shim) {
+        g_glGetProgramiv_shim = (glGetProgramivShimProc)ng_gl4es_lookup_proc_raw("glGetProgramiv");
+    }
+
+    if (g_glGetProgramiv_shim) {
+        g_glGetProgramiv_shim(program, pname, &value);
+    }
+
+    return value;
+}
+
+static int ng_gl4es_glGetShaderi(unsigned int shader, unsigned int pname) {
+    int value = 0;
+
+    if (!g_glGetShaderiv_shim) {
+        g_glGetShaderiv_shim = (glGetShaderivShimProc)ng_gl4es_lookup_proc_raw("glGetShaderiv");
