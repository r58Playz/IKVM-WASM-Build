diff --git a/src/gl/emscripten_aliases.c b/src/gl/emscripten_aliases.c
new file mode 100644
index 0000000..7bbf664
--- /dev/null
+++ b/src/gl/emscripten_aliases.c
@@ -0,0 +1,119 @@
+// On Emscripten the AliasExport macro in attributes.h falls back to a
+// declaration-only stub, so the gl4es_glXXX aliases that the non-Emscripten
+// build emits via __attribute__((alias)) are missing. The proc-address
+// dispatch in gl_lookup.c (including the included glesfuncs.inc) references
+// gl4es_glXXX names unconditionally, so the linker needs those symbols to
+// resolve.
+//
+// This file provides thunks for functions whose canonical definitions live as
+// plain glXXX names (no gl4es_ prefix). Sources of the originals:
+//   - src/gl/wrap/glesnative.cpp - NATIVE_FUNCTION_HEAD definitions
+//   - src/gl/framebuffers.c     - VISIBLE void glReadBuffer
+//   - src/gl/buffers.c          - VISIBLE void glTexBuffer
+//   - VISIBLE void glVertexAttribI* / glBindFragDataLocationIndexed / etc.
+//
+// The bodies forward to the upstream un-prefixed names. The thunks are only
+// reachable via the proc-address dispatch in gl_lookup.c, so the extra call
+// frame is paid only on glfwGetProcAddress / krypton_get_proc_address.
+
+#if defined(__EMSCRIPTEN__)
+
+#include <GL/gl.h>
+#include <stddef.h>
+#include <stdint.h>
+
+/* Declarations of the canonical (un-prefixed) targets. */
+extern GLsync   krypton_glFenceSync(GLenum, GLbitfield);
+extern GLboolean krypton_glIsSync(GLsync);
+extern void     krypton_glDeleteSync(GLsync);
+extern GLenum   krypton_glClientWaitSync(GLsync, GLbitfield, GLuint64);
+extern void     krypton_glWaitSync(GLsync, GLbitfield, GLuint64);
+extern void     krypton_glGetSynciv(GLsync, GLenum, GLsizei, GLsizei*, GLint*);
+extern void     krypton_glDrawArraysIndirect(GLenum, const void*);
+extern void     krypton_glReadBuffer(GLenum);
+extern void     krypton_glBindFragDataLocationIndexed(GLuint, GLuint, GLuint, const char*);
+extern GLint    krypton_glGetFragDataIndex(GLuint, const char*);
+extern GLint    krypton_glGetProgramResourceLocationIndex(GLuint, GLenum, const char*);
+extern void     krypton_glGetVertexAttribIiv(GLuint, GLenum, GLint*);
+extern void     krypton_glGetVertexAttribIuiv(GLuint, GLenum, GLuint*);
+extern void     krypton_glVertexAttribI1i(GLuint, GLint);
+extern void     krypton_glVertexAttribI1iv(GLuint, const GLint*);
+extern void     krypton_glVertexAttribI1ui(GLuint, GLuint);
+extern void     krypton_glVertexAttribI1uiv(GLuint, const GLuint*);
+extern void     krypton_glVertexAttribI2i(GLuint, GLint, GLint);
+extern void     krypton_glVertexAttribI2iv(GLuint, const GLint*);
+extern void     krypton_glVertexAttribI2ui(GLuint, GLuint, GLuint);
+extern void     krypton_glVertexAttribI2uiv(GLuint, const GLuint*);
+extern void     krypton_glVertexAttribI3i(GLuint, GLint, GLint, GLint);
+extern void     krypton_glVertexAttribI3iv(GLuint, const GLint*);
+extern void     krypton_glVertexAttribI3ui(GLuint, GLuint, GLuint, GLuint);
+extern void     krypton_glVertexAttribI3uiv(GLuint, const GLuint*);
+extern void     krypton_glVertexAttribI4i(GLuint, GLint, GLint, GLint, GLint);
+extern void     krypton_glVertexAttribI4iv(GLuint, const GLint*);
+extern void     krypton_glVertexAttribI4ui(GLuint, GLuint, GLuint, GLuint, GLuint);
+extern void     krypton_glVertexAttribI4uiv(GLuint, const GLuint*);
+extern void     krypton_glVertexAttribP1ui(GLuint, GLenum, GLboolean, GLuint);
+extern void     krypton_glVertexAttribP1uiv(GLuint, GLenum, GLboolean, const GLuint*);
+extern void     krypton_glVertexAttribP2ui(GLuint, GLenum, GLboolean, GLuint);
+extern void     krypton_glVertexAttribP2uiv(GLuint, GLenum, GLboolean, const GLuint*);
+extern void     krypton_glVertexAttribP3ui(GLuint, GLenum, GLboolean, GLuint);
+extern void     krypton_glVertexAttribP3uiv(GLuint, GLenum, GLboolean, const GLuint*);
+extern void     krypton_glVertexAttribP4ui(GLuint, GLenum, GLboolean, GLuint);
+extern void     krypton_glVertexAttribP4uiv(GLuint, GLenum, GLboolean, const GLuint*);
+extern void     krypton_glVertexAttribLPointer(GLuint, GLint, GLenum, GLsizei, const void*);
+
+#define THUNK0(ret, name) \
+    ret gl4es_##name(void) { return (ret)0; (void)0; }
+
+/* Thunks forward to the krypton_-prefixed canonicals defined in NG-GL4ES
+ * (see krypton_export_names.h + KW_EXPORT() at each glXXX definition). The
+ * concat with ## means `name` isn't pre-expanded, so e.g. THUNK_V(glReadBuffer)
+ * yields a body that calls `krypton_glReadBuffer(s);` regardless of whether
+ * `glReadBuffer` is otherwise a macro elsewhere in the build.
+ */
+#define THUNK_V(name, sig, args) \
+    void gl4es_##name sig { krypton_##name args; }
+
+#define THUNK_R(ret, name, sig, args) \
+    ret gl4es_##name sig { return krypton_##name args; }
+
+THUNK_R(GLsync,    glFenceSync, (GLenum c, GLbitfield f), (c, f))
+THUNK_R(GLboolean, glIsSync,    (GLsync s), (s))
+THUNK_V(           glDeleteSync,(GLsync s), (s))
+THUNK_R(GLenum,    glClientWaitSync, (GLsync s, GLbitfield f, GLuint64 t), (s, f, t))
+THUNK_V(           glWaitSync,  (GLsync s, GLbitfield f, GLuint64 t), (s, f, t))
+THUNK_V(           glGetSynciv, (GLsync s, GLenum p, GLsizei b, GLsizei* l, GLint* v), (s, p, b, l, v))
+THUNK_V(           glDrawArraysIndirect, (GLenum m, const void* i), (m, i))
+THUNK_V(           glReadBuffer, (GLenum s), (s))
+THUNK_V(           glBindFragDataLocationIndexed, (GLuint p, GLuint c, GLuint i, const char* n), (p, c, i, n))
+THUNK_R(GLint,     glGetFragDataIndex, (GLuint p, const char* n), (p, n))
+THUNK_R(GLint,     glGetProgramResourceLocationIndex, (GLuint p, GLenum i, const char* n), (p, i, n))
+THUNK_V(           glGetVertexAttribIiv, (GLuint i, GLenum p, GLint* v), (i, p, v))
+THUNK_V(           glGetVertexAttribIuiv, (GLuint i, GLenum p, GLuint* v), (i, p, v))
+THUNK_V(           glVertexAttribI1i,    (GLuint i, GLint x), (i, x))
+THUNK_V(           glVertexAttribI1iv,   (GLuint i, const GLint* v), (i, v))
+THUNK_V(           glVertexAttribI1ui,   (GLuint i, GLuint x), (i, x))
+THUNK_V(           glVertexAttribI1uiv,  (GLuint i, const GLuint* v), (i, v))
+THUNK_V(           glVertexAttribI2i,    (GLuint i, GLint x, GLint y), (i, x, y))
+THUNK_V(           glVertexAttribI2iv,   (GLuint i, const GLint* v), (i, v))
+THUNK_V(           glVertexAttribI2ui,   (GLuint i, GLuint x, GLuint y), (i, x, y))
+THUNK_V(           glVertexAttribI2uiv,  (GLuint i, const GLuint* v), (i, v))
+THUNK_V(           glVertexAttribI3i,    (GLuint i, GLint x, GLint y, GLint z), (i, x, y, z))
+THUNK_V(           glVertexAttribI3iv,   (GLuint i, const GLint* v), (i, v))
+THUNK_V(           glVertexAttribI3ui,   (GLuint i, GLuint x, GLuint y, GLuint z), (i, x, y, z))
+THUNK_V(           glVertexAttribI3uiv,  (GLuint i, const GLuint* v), (i, v))
+THUNK_V(           glVertexAttribI4i,    (GLuint i, GLint x, GLint y, GLint z, GLint w), (i, x, y, z, w))
+THUNK_V(           glVertexAttribI4iv,   (GLuint i, const GLint* v), (i, v))
+THUNK_V(           glVertexAttribI4ui,   (GLuint i, GLuint x, GLuint y, GLuint z, GLuint w), (i, x, y, z, w))
+THUNK_V(           glVertexAttribI4uiv,  (GLuint i, const GLuint* v), (i, v))
+THUNK_V(           glVertexAttribP1ui,   (GLuint i, GLenum t, GLboolean n, GLuint v), (i, t, n, v))
+THUNK_V(           glVertexAttribP1uiv,  (GLuint i, GLenum t, GLboolean n, const GLuint* v), (i, t, n, v))
+THUNK_V(           glVertexAttribP2ui,   (GLuint i, GLenum t, GLboolean n, GLuint v), (i, t, n, v))
+THUNK_V(           glVertexAttribP2uiv,  (GLuint i, GLenum t, GLboolean n, const GLuint* v), (i, t, n, v))
+THUNK_V(           glVertexAttribP3ui,   (GLuint i, GLenum t, GLboolean n, GLuint v), (i, t, n, v))
+THUNK_V(           glVertexAttribP3uiv,  (GLuint i, GLenum t, GLboolean n, const GLuint* v), (i, t, n, v))
+THUNK_V(           glVertexAttribP4ui,   (GLuint i, GLenum t, GLboolean n, GLuint v), (i, t, n, v))
+THUNK_V(           glVertexAttribP4uiv,  (GLuint i, GLenum t, GLboolean n, const GLuint* v), (i, t, n, v))
+THUNK_V(           glVertexAttribLPointer, (GLuint i, GLint s, GLenum t, GLsizei st, const void* p), (i, s, t, st, p))
+
+#endif /* __EMSCRIPTEN__ */
