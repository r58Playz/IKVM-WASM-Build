+static void ng_gl4es_get_mainfb_size(int* width, int* height) {
+    int canvas_width = 0;
+    int canvas_height = 0;
+    EMSCRIPTEN_WEBGL_CONTEXT_HANDLE context = emscripten_webgl_get_current_context();
+
+    if (context > 0 && emscripten_webgl_get_drawing_buffer_size(context, &canvas_width, &canvas_height) ==
+                           EMSCRIPTEN_RESULT_SUCCESS) {
+        if (width) {
+            *width = canvas_width;
+        }
+        if (height) {
+            *height = canvas_height;
+        }
+        return;
+    }
+
+    if (emscripten_get_canvas_element_size(g_ng_gl4es_canvas_selector, &canvas_width, &canvas_height) ==
+        EMSCRIPTEN_RESULT_SUCCESS) {
+        if (width) {
+            *width = canvas_width;
+        }
+        if (height) {
+            *height = canvas_height;
+        }
+    }
+}
