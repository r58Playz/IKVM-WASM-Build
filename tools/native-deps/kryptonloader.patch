+#define LOAD_GLES3_OR_EXT(name)                                                                                        \
+    DEFINE_RAW(gles, name);                                                                                            \
+    {                                                                                                                  \
+        static bool first = true;                                                                                      \
+        if (first) {                                                                                                   \
+            first = false;                                                                                             \
+            if (gles != NULL) {                                                                                        \
+                name##_PTR origin = (name##_PTR)proc_address(gles, #name);                                            \
+                gles_##name = (name##_PTR)(origin ? origin : proc_address(gles, #name "EXT"));                       \
+            }                                                                                                          \
+            WARN_NULL(gles_##name);                                                                                    \
+        }                                                                                                              \
+    }
+
 #else // defined(AMIGAOS4) || defined(NOEGL)
 
 #define LOAD_EGL_EXT(name)                                                                                             \
