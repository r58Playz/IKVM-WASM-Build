+ *   window.tinyfd = {
+ *     beep:               function() {},
+ *     notifyPopup:        function(title, message, iconType) -> int,
+ *     messageBox:         function(title, message, dialogType, iconType, defaultButton) -> int,
+ *     inputBox:           function(title, message, defaultInput) -> string|null,
+ *     saveFileDialog:     function(title, defaultPathAndFile, filterPatterns[], filterDescription) -> string|null,
+ *     openFileDialog:     function(title, defaultPathAndFile, filterPatterns[], filterDescription, allowMultiple) -> string|null,
