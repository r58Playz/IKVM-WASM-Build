@@ -0,0 +1,41 @@
+/*
+ * Copyright LWJGL. All rights reserved.
+ * License terms: https://www.lwjgl.org/license
+ */
+#include "common_tools.h"
+
+extern void* JVM_LoadLibrary(const char* name) __attribute__((weak));
+extern void* JVM_FindLibraryEntry(void* handle, const char* name) __attribute__((weak));
+
+static void throwUnsatisfiedLinkError(JNIEnv* env, const char* message) {
+    jclass errorClass = (*env)->FindClass(env, "java/lang/UnsatisfiedLinkError");
+    if (errorClass != NULL) {
+        (*env)->ThrowNew(env, errorClass, message);
+    }
+}
+
+EXTERN_C_ENTER
+
+JNIEXPORT jlong JNICALL Java_org_lwjgl_system_linux_StaticLinkLoader_nloadLibrary(JNIEnv *env, jclass clazz, jlong nameAddress) {
+    UNUSED_PARAM(clazz)
+
+    if (JVM_LoadLibrary == NULL) {
+        throwUnsatisfiedLinkError(env, "JVM_LoadLibrary is unavailable in this runtime");
+        return 0;
+    }
+
+    return (jlong)(uintptr_t)JVM_LoadLibrary((const char*)(uintptr_t)nameAddress);
+}
+
+JNIEXPORT jlong JNICALL Java_org_lwjgl_system_linux_StaticLinkLoader_nfindLibraryEntry(JNIEnv *env, jclass clazz, jlong handleAddress, jlong nameAddress) {
+    UNUSED_PARAM(clazz)
+
+    if (JVM_FindLibraryEntry == NULL) {
+        throwUnsatisfiedLinkError(env, "JVM_FindLibraryEntry is unavailable in this runtime");
+        return 0;
+    }
+
+    return (jlong)(uintptr_t)JVM_FindLibraryEntry((void*)(uintptr_t)handleAddress, (const char*)(uintptr_t)nameAddress);
+}
+
+EXTERN_C_EXIT
