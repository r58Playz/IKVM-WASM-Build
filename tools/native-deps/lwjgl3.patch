+    ffi_status st = ffi_prep_cif(&e->cif, FFI_DEFAULT_ABI, (unsigned)nargs, rettype, e->arg_types);
+    if (st != FFI_OK) {
+        DCB_ERR("ffi_prep_cif failed: status=%d sig=\"%s\"\n",
+            (int)st, (const char*)(intptr_t)signatureAddress);
