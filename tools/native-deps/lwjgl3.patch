--- /dev/null
+++ b/modules/lwjgl/core/src/main/java/org/lwjgl/system/linux/StaticLinkLoader.java
@@ -0,0 +1,45 @@
+/*
+ * Copyright LWJGL. All rights reserved.
+ * License terms: https://www.lwjgl.org/license
+ */
+package org.lwjgl.system.linux;
+
+import java.nio.*;
+
+import org.lwjgl.system.*;
+
+import static org.lwjgl.system.Checks.*;
+import static org.lwjgl.system.MemoryStack.*;
+import static org.lwjgl.system.MemoryUtil.*;
+
+final class StaticLinkLoader {
+
+    static { Library.initialize(); }
+
+    private StaticLinkLoader() {
+        throw new UnsupportedOperationException();
+    }
+
+    private static native long nloadLibrary(long name);
+
+    static long loadLibrary(CharSequence name) {
+        MemoryStack stack = stackGet(); int stackPointer = stack.getPointer();
+        try {
+            stack.nASCII(name, true);
+            return nloadLibrary(stack.getPointerAddress());
+        } finally {
+            stack.setPointer(stackPointer);
+        }
+    }
+
+    private static native long nfindLibraryEntry(long handle, long name);
+
+    static long findLibraryEntry(long handle, ByteBuffer name) {
+        if (CHECKS) {
+            check(handle);
+            checkNT1(name);
+        }
+        return nfindLibraryEntry(handle, memAddress(name));
+    }
+
+}
diff --git a/modules/lwjgl/core/src/main/c/dyncall_libffi_bridge.c b/modules/lwjgl/core/src/main/c/dyncall_libffi_bridge.c
new file mode 100644
index 0000000..315320c
--- /dev/null
+++ b/modules/lwjgl/core/src/main/c/dyncall_libffi_bridge.c
@@ -0,0 +1,412 @@
+/*
+ * Bridge: dyncall callback API → libffi closures.
+ *
+ * LWJGL 3.2.2 wraps dyncall for FFI/callback support. Upstream LWJGL ships
+ * libdyncall_s.a/libdyncallback_s.a binaries for x86/ARM Linux/macOS/Windows,
+ * not for Emscripten/wasm. This file reimplements just enough of the
+ * dyncallback API (dcbNewCallback/dcbFreeCallback + dcbArg*) on top of
+ * libffi closures so that LWJGL's Callback machinery works on wasm.
+ *
+ * Notes
+ * -----
+ * - Only the parts of dyncall used by LWJGL's Callback/CallbackI plumbing are
+ *   covered. dcCall* (forward calls) and DynLoad are out of scope; LWJGL only
+ *   uses dcCall for the generic Function path, which our bindings (glfw, gl,
+ *   stb) bypass via per-method JNI.
+ * - The handle returned by dcbNewCallback is the libffi closure's executable
+ *   code address. A small global map records the metadata needed to free it
+ *   later (libffi requires the writable closure pointer, not the executable
+ *   one, for ffi_closure_free).
+ */
+
+#include "common_tools.h"
+#include "ffi.h"
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <pthread.h>
+
+/* Failure paths always log; successful traces are gated on IKVM_DCB_DEBUG. */
+#define DCB_ERR(...) do { fprintf(stderr, "[dcb] " __VA_ARGS__); fflush(stderr); } while (0)
+#define DCB_LOG(...) do { \
+    static int _dcb_debug = -1; \
+    if (_dcb_debug < 0) { \
+        const char* _v = getenv("IKVM_DCB_DEBUG"); \
+        _dcb_debug = (_v && _v[0] && _v[0] != '0') ? 1 : 0; \
+    } \
+    if (_dcb_debug) { fprintf(stderr, "[dcb] " __VA_ARGS__); fflush(stderr); } \
+} while (0)
+
+/* DCArgs replacement: cursor over libffi-supplied args. */
+typedef struct dc_args_s {
+    void** args;
+    int    cursor;
+} dc_args_t;
+
+/* dyncall callback handler signature (see dyncall_callback.h). */
+typedef char (*dc_handler_fn)(void* cb, dc_args_t* args, void* result, void* userdata);
+
+/* Per-callback metadata. */
+typedef struct dc_entry_s {
+    void*              code;        /* executable address — what callers pass back to free */
+    ffi_closure*       closure;     /* writable closure pointer (for ffi_closure_free) */
+    ffi_cif            cif;
+    ffi_type**         arg_types;
+    int                nargs;
+    dc_handler_fn      user_handler;
+    void*              user_data;
+    struct dc_entry_s* next;
+} dc_entry_t;
+
+static dc_entry_t*     g_entries = NULL;
+static pthread_mutex_t g_lock    = PTHREAD_MUTEX_INITIALIZER;
+
+static void entry_register(dc_entry_t* e) {
+    pthread_mutex_lock(&g_lock);
+    e->next   = g_entries;
+    g_entries = e;
+    pthread_mutex_unlock(&g_lock);
+}
+
+static dc_entry_t* entry_unregister(void* code) {
+    pthread_mutex_lock(&g_lock);
+    dc_entry_t* prev = NULL;
+    dc_entry_t* e    = g_entries;
+    while (e && e->code != code) {
+        prev = e;
+        e    = e->next;
+    }
+    if (e) {
+        if (prev) prev->next = e->next;
+        else      g_entries  = e->next;
+    }
+    pthread_mutex_unlock(&g_lock);
+    return e;
+}
+
+/* dyncall sig char → libffi type. Returns NULL on unknown char. */
+static ffi_type* sig_to_ffi(char c) {
+    switch (c) {
+        case 'v': return &ffi_type_void;
+        case 'B': return &ffi_type_uint8;   /* bool */
+        case 'c': return &ffi_type_sint8;
+        case 'C': return &ffi_type_uint8;
+        case 's': return &ffi_type_sint16;
+        case 'S': return &ffi_type_uint16;
+        case 'i': return &ffi_type_sint32;
+        case 'I': return &ffi_type_uint32;
+        case 'j': return sizeof(long) == 8 ? &ffi_type_sint64 : &ffi_type_sint32;
+        case 'J': return sizeof(long) == 8 ? &ffi_type_uint64 : &ffi_type_uint32;
+        case 'l': return &ffi_type_sint64;
+        case 'L': return &ffi_type_uint64;
+        case 'f': return &ffi_type_float;
+        case 'd': return &ffi_type_double;
+        case 'p':
+        case 'Z': return &ffi_type_pointer;
+        default:  return NULL;
+    }
+}
+
+/* libffi closure callback: bridges to dyncall-style handler.
+ *
+ * Note on the ret buffer: libffi promises ffi_arg-aligned storage for narrow
+ * integer return types (bool/byte/short). LWJGL's cbHandlerZ/B/S write only
+ * sizeof(jboolean|jbyte|jshort), leaving upper bits undefined for libffi's
+ * caller. Pre-zero the slot so partial writes are safe. Void returns are a
+ * no-op for libffi here, so skipping is fine but the memset costs little. */
+static void closure_trampoline(ffi_cif* cif, void* ret, void** args, void* user_data) {
+    dc_entry_t* e = (dc_entry_t*)user_data;
+    dc_args_t   a = { args, 0 };
+    if (ret != NULL && cif->rtype != NULL && cif->rtype != &ffi_type_void) {
+        size_t sz = cif->rtype->size;
+        if (sz < sizeof(ffi_arg)) sz = sizeof(ffi_arg);
+        memset(ret, 0, sz);
+    }
+    e->user_handler(e, &a, ret, e->user_data);
+}
+
+EXTERN_C_ENTER
+
+JNIEXPORT jlong JNICALL Java_org_lwjgl_system_dyncall_DynCallback_ndcbNewCallback(
+    JNIEnv* env, jclass clazz, jlong signatureAddress, jlong funcptrAddress, jlong userdataAddress
+) {
+    UNUSED_PARAMS(env, clazz)
+
+    const char* sig = (const char*)(intptr_t)signatureAddress;
+    if (sig == NULL) { DCB_ERR("ndcbNewCallback: signatureAddress=0\n"); return 0; }
+
+    DCB_LOG("ndcbNewCallback enter: sig=\"%s\" funcptr=%p ud=%p\n",
+        sig, (void*)(intptr_t)funcptrAddress, (void*)(intptr_t)userdataAddress);
+
+    /* Skip optional calling-convention prefix: '_' followed by a cc char. */
+    if (sig[0] == '_' && sig[1] != '\0') sig += 2;
+
+    /* LWJGL writes signatures as "(args)ret". The leading '(' is optional in
+     * dyncall's grammar (it's just an opening marker), but LWJGL always includes
+     * it, so skip if present. */
+    if (sig[0] == '(') sig += 1;
+
+    /* Count argument chars up to ')'. */
+    const char* p = sig;
+    int nargs = 0;
+    while (*p && *p != ')') { nargs++; p++; }
+    if (*p != ')' || *(p + 1) == '\0') {
+        DCB_ERR("ndcbNewCallback: malformed signature \"%s\"\n",
+            (const char*)(intptr_t)signatureAddress);
+        return 0;
+    }
+    char retchar = *(p + 1);
+
+    dc_entry_t* e = (dc_entry_t*)calloc(1, sizeof(dc_entry_t));
+    if (e == NULL) { DCB_ERR("calloc(dc_entry_t) failed\n"); return 0; }
+    e->nargs        = nargs;
+    e->user_handler = (dc_handler_fn)(intptr_t)funcptrAddress;
+    e->user_data    = (void*)(intptr_t)userdataAddress;
+
+    if (nargs > 0) {
+        e->arg_types = (ffi_type**)malloc(sizeof(ffi_type*) * nargs);
