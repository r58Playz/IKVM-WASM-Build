@@ -0,0 +1,45 @@
+/*
+ * Copyright LWJGL. All rights reserved.
+ * License terms: https://www.lwjgl.org/license
+ */
+package org.lwjgl.system.linux;
+
+import java.nio.*;
+
+import org.lwjgl.system.*;
+
+import static org.lwjgl.system.Checks.*;
+import static org.lwjgl.system.MemoryStack.*;
+import static org.lwjgl.system.MemoryUtil.*;
+
+final class StaticLinkLoader {
+
+    static { Library.initialize(); }
+
+    private StaticLinkLoader() {
+        throw new UnsupportedOperationException();
+    }
+
+    private static native long nloadLibrary(long name);
+
+    static long loadLibrary(CharSequence name) {
+        MemoryStack stack = stackGet(); int stackPointer = stack.getPointer();
+        try {
+            stack.nUTF8(name, true);
+            return nloadLibrary(stack.getPointerAddress());
+        } finally {
+            stack.setPointer(stackPointer);
+        }
+    }
+
+    private static native long nfindLibraryEntry(long handle, long name);
+
+    static long findLibraryEntry(long handle, ByteBuffer name) {
+        if (CHECKS) {
+            check(handle);
+            checkNT1(name);
+        }
+        return nfindLibraryEntry(handle, memAddress(name));
+    }
+
+}
