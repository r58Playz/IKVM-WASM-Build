+void glPrimitiveRestartIndex(GLuint index) {
+    LOG()
+    LOG_D("glPrimitiveRestartIndex, index: 0x%x", index)
+
+    switch (index) {
+    case 0xFFu:
+    case 0xFFFFu:
+    case 0xFFFFFFFFu:
+        // GLES 3.0 / WebGL2 only support fixed-index primitive restart.
+        return;
+    default:
+        LOG_W_FORCE("glPrimitiveRestartIndex: unsupported custom restart index 0x%x on GLES fixed-index restart", index)
+        return;
+    }
+}
