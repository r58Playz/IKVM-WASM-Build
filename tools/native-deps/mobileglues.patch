+bool mgReadBufferSubData(GLenum target, GLintptr offset, GLsizeiptr size, void* data) {
+    if (size <= 0) return true;
+    if (!data) return false;
+    if (offset < 0) return false;
+
+    GLuint fake_buffer = find_bound_buffer(target);
+    if (!fake_buffer || !has_buffer(fake_buffer)) return false;
+
+    size_t tracked_size = get_buffer_data_size(fake_buffer);
+    if (tracked_size > 0) {
+        const size_t offset_s = static_cast<size_t>(offset);
+        const size_t size_s = static_cast<size_t>(size);
+        if (offset_s > tracked_size || size_s > tracked_size - offset_s) {
+            return false;
+        }
+    }
+
+    GLuint real_buffer = find_real_buffer(fake_buffer);
+    if (!real_buffer) return false;
+
+    const GLenum backend_target = map_buffer_target_for_backend(target);
+    GLint prev_backend_binding = 0;
+    const GLenum backend_binding_query = get_binding_query(backend_target);
+    if (backend_binding_query != 0) {
+        GLES.glGetIntegerv(backend_binding_query, &prev_backend_binding);
+    }
+
+    GLES.glBindBuffer(backend_target, real_buffer);
+
+    bool success = false;
+
+    if (GLES.glGetBufferSubData) {
+        GLES.glGetBufferSubData(backend_target, offset, size, data);
+        success = (GLES.glGetError() == GL_NO_ERROR);
+    }
+
+#ifndef __EMSCRIPTEN__
+    if (!success && g_gles_caps.GL_OES_mapbuffer) {
+        void* mapped = GLES.glMapBufferOES(backend_target, GL_READ_ONLY);
+        if (mapped) {
+            memcpy(data, reinterpret_cast<const uint8_t*>(mapped) + offset, static_cast<size_t>(size));
+            GLES.glUnmapBuffer(backend_target);
+            success = true;
+        }
+    }
+#endif
+
+    if (backend_binding_query != 0) {
+        GLES.glBindBuffer(backend_target, static_cast<GLuint>(prev_backend_binding));
+    }
+
+    return success;
+}
+
+static inline GLenum map_buffer_target_for_backend(GLenum target) {
+    switch (target) {
+    case GL_TEXTURE_BUFFER:
+        // GLES/WebGL do not support GL_TEXTURE_BUFFER as a bind target for glBindBuffer/glBufferData.
+        // Route storage ops through GL_ARRAY_BUFFER while keeping desktop binding state in g_bound_buffers_arr.
+        return GL_ARRAY_BUFFER;
+#ifdef __EMSCRIPTEN__
+    case GL_ATOMIC_COUNTER_BUFFER:
+    case GL_DRAW_INDIRECT_BUFFER:
+    case GL_DISPATCH_INDIRECT_BUFFER:
+#ifdef GL_QUERY_BUFFER
+    case GL_QUERY_BUFFER:
+#endif
+        // WebGL does not expose these desktop/ES3.1+ targets on glBindBuffer/glBufferData.
+        // Keep logical bindings in g_bound_buffers_arr and use ARRAY_BUFFER for backing storage ops.
+        return GL_ARRAY_BUFFER;
+#endif
+    default:
+        return target;
+    }
+}
+
+static inline bool is_emulated_buffer_target(GLenum target) {
+    return map_buffer_target_for_backend(target) != target;
+}
