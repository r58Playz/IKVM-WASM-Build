+
+static void* mobileglues_find_linked_symbol(const char* name) {
+    if (!JVM_LoadLibrary || !JVM_FindLibraryEntry) {
+        return nullptr;
+    }
+
+    static void* handle = nullptr;
+    if (!handle) {
+        const char* candidates[] = {"glfw3", "libglfw3.so", "libglfw3.a", "glfw", nullptr};
+        for (int i = 0; candidates[i]; ++i) {
+            handle = JVM_LoadLibrary(candidates[i]);
+            if (handle) {
+                break;
+            }
+        }
+    }
+
+    if (!handle) {
+        return nullptr;
+    }
+
+	return JVM_FindLibraryEntry(handle, name);
+}
+
+static void* mobileglues_builtin_proc_address(const std::string& name) {
+    // These wrappers are implemented inside the linked MobileGlues archive, but
+    // Emscripten's GL proc lookup cannot see them and JVM symbol lookup may not
+    // surface them as dynamic exports. Return their addresses directly so LWJGL
+    // does not install its zero-arg missing-function trampoline.
+    if (name == "glPrimitiveRestartIndex") return reinterpret_cast<void*>(glPrimitiveRestartIndex);
+    if (name == "glTexBuffer") return reinterpret_cast<void*>(glTexBuffer);
+    if (name == "glTexBufferRange") return reinterpret_cast<void*>(glTexBufferRange);
+    if (name == "glDrawElementsBaseVertex") return reinterpret_cast<void*>(glDrawElementsBaseVertex);
+    if (name == "glMultiDrawElements") return reinterpret_cast<void*>(glMultiDrawElements);
