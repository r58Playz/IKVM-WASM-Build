+EMSCRIPTEN_RESULT mobileglues_webgl_make_context_current(EMSCRIPTEN_WEBGL_CONTEXT_HANDLE context) {
+    if (!g_initialized) {
+        proc_init();
+    }
+    return emscripten_webgl_make_context_current(context);
+}
+
+EMSCRIPTEN_RESULT mobileglues_webgl_destroy_context(EMSCRIPTEN_WEBGL_CONTEXT_HANDLE context) {
+    if (!g_initialized) {
+        proc_init();
+    }
+    return emscripten_webgl_destroy_context(context);
+}
