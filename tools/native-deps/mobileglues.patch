+    if (name == "mg_glMultiDrawElements_multiindirect") return reinterpret_cast<void*>(mg_glMultiDrawElements_multiindirect);
+    if (name == "mg_glMultiDrawElements_basevertex") return reinterpret_cast<void*>(mg_glMultiDrawElements_basevertex);
+    if (name == "mg_glMultiDrawElements_drawelements") return reinterpret_cast<void*>(mg_glMultiDrawElements_drawelements);
+    if (name == "mg_glMultiDrawElements_compute") return reinterpret_cast<void*>(mg_glMultiDrawElements_compute);
+    if (name == "mg_glMultiDrawElementsBaseVertex_indirect") return reinterpret_cast<void*>(mg_glMultiDrawElementsBaseVertex_indirect);
+    if (name == "mg_glMultiDrawElementsBaseVertex_multiindirect") return reinterpret_cast<void*>(mg_glMultiDrawElementsBaseVertex_multiindirect);
+    if (name == "mg_glMultiDrawElementsBaseVertex_basevertex") return reinterpret_cast<void*>(mg_glMultiDrawElementsBaseVertex_basevertex);
+    if (name == "mg_glMultiDrawElementsBaseVertex_drawelements") return reinterpret_cast<void*>(mg_glMultiDrawElementsBaseVertex_drawelements);
+    if (name == "mg_glMultiDrawElementsBaseVertex_compute") return reinterpret_cast<void*>(mg_glMultiDrawElementsBaseVertex_compute);
+
+    return nullptr;
+}
