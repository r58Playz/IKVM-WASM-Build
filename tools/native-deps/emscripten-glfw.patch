diff --git a/src/cpp/emscripten/glfw3/EventQueue.cpp b/src/cpp/emscripten/glfw3/EventQueue.cpp
new file mode 100644
index 0000000..d208959
--- /dev/null
+++ b/src/cpp/emscripten/glfw3/EventQueue.cpp
@@ -0,0 +1,53 @@
+#include "EventQueue.h"
+
+namespace emscripten::glfw3 {
+
+EventQueue &EventQueue::instance()
+{
+  static EventQueue sInstance;
+  return sInstance;
+}
+
+bool EventQueue::push(EventInvoker iInvoker,
+                      void *iUserData,
+                      int32_t iEventType,
+                      void const *iPayload,
+                      int32_t iPayloadSize)
+{
+  if(iPayloadSize < 0 || static_cast<size_t>(iPayloadSize) > kEventMaxPayloadBytes)
+    return false;
+
+  uint32_t tail = fTail.load(std::memory_order_relaxed);
+  uint32_t head = fHead.load(std::memory_order_acquire);
+  uint32_t next = (tail + 1) % kEventQueueCapacity;
+  if(next == head)
+    return false;
+
+  EventSlot &slot = fSlots[tail];
+  slot.invoker = iInvoker;
+  slot.userData = iUserData;
+  slot.eventType = iEventType;
+  slot.payloadSize = iPayloadSize;
+  if(iPayloadSize > 0 && iPayload)
+    std::memcpy(slot.payload, iPayload, static_cast<size_t>(iPayloadSize));
+
+  fTail.store(next, std::memory_order_release);
+  return true;
+}
+
+void EventQueue::drain()
+{
+  uint32_t head = fHead.load(std::memory_order_relaxed);
+  uint32_t tail = fTail.load(std::memory_order_acquire);
+  while(head != tail)
+  {
+    EventSlot &slot = fSlots[head];
+    void const *payload = slot.payloadSize > 0 ? static_cast<void const *>(slot.payload) : nullptr;
+    slot.invoker(slot.userData, slot.eventType, payload);
+    head = (head + 1) % kEventQueueCapacity;
+    fHead.store(head, std::memory_order_release);
+    tail = fTail.load(std::memory_order_acquire);
+  }
+}
+
+}
diff --git a/src/cpp/emscripten/glfw3/EventQueue.h b/src/cpp/emscripten/glfw3/EventQueue.h
new file mode 100644
index 0000000..093b88d
--- /dev/null
+++ b/src/cpp/emscripten/glfw3/EventQueue.h
@@ -0,0 +1,63 @@
+/*
+ * SPSC event ring used to move DOM events off the pthread proxy mailbox.
+ * Producer = main browser thread (HTML5 callbacks installed with
+ * EM_CALLBACK_THREAD_CONTEXT_MAIN_BROWSER_THREAD, plus JS-side handlers).
+ * Consumer = render worker, draining inside Context::pollEvents().
+ *
+ * All listener lambdas continue to run on the worker — we only short-circuit
+ * the dispatch path so main never enqueues into the worker's blocked mailbox.
+ */
+
+#ifndef EMSCRIPTEN_GLFW_EVENT_QUEUE_H
+#define EMSCRIPTEN_GLFW_EVENT_QUEUE_H
+
+#include <atomic>
+#include <cstddef>
+#include <cstdint>
+#include <cstring>
+
+namespace emscripten::glfw3 {
+
+using EventInvoker = bool (*)(void *iUserData, int32_t iEventType, void const *iPayload);
+
+constexpr size_t kEventQueueCapacity = 64;
+constexpr size_t kEventMaxPayloadBytes = 2032;
+
+struct EventSlot
+{
+  EventInvoker invoker;
+  void *userData;
+  int32_t eventType;
+  int32_t payloadSize;
+  alignas(8) uint8_t payload[kEventMaxPayloadBytes];
+};
+
+class EventQueue
+{
+public:
+  static EventQueue &instance();
+
+  // main thread: enqueue a record. Returns false if the queue is full (event dropped).
+  bool push(EventInvoker iInvoker,
+            void *iUserData,
+            int32_t iEventType,
+            void const *iPayload,
+            int32_t iPayloadSize);
+
+  // worker thread: drain everything currently pending.
+  void drain();
+
+private:
+  EventQueue() = default;
+
+  std::atomic<uint32_t> fHead{0};
+  std::atomic<uint32_t> fTail{0};
+  EventSlot fSlots[kEventQueueCapacity]{};
+};
+
+template<typename E>
+bool EventListenerInvoke(void *iUserData, int32_t iEventType, void const *iPayload);
+
+}
+
+#endif // EMSCRIPTEN_GLFW_EVENT_QUEUE_H
