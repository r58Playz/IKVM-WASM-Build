+// - executor called by EventQueue::drain on the worker; reconstructs the
+//   typed pointer and runs the original lambda.
+//------------------------------------------------------------------------
+template<typename E>
+bool EventListenerInvoke(void *iUserData, int32_t iEventType, void const *iPayload)
+{
+  auto cb = reinterpret_cast<EventListener<E> *>(iUserData);
+  if constexpr(std::is_void_v<E>)
