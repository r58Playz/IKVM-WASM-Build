+GLFWAPI void glfwSwapBuffers(GLFWwindow* window)
+{
+  auto w = getWindow(window);
+  if(!w)
+    return;
+
+  if(!w->hasGLContext())
+  {
+    ErrorHandler::instance().logError(GLFW_NO_WINDOW_CONTEXT,
+                                      "Cannot swap buffers for a window without an OpenGL or OpenGL ES context");
+    return;
+  }
+
+  auto context = getContext();
+  if(!context)
+    return;
+
+  if(context->getCurrentContext() != window)
+  {
+    ErrorHandler::instance().logError(GLFW_NO_CURRENT_CONTEXT,
+                                      "Cannot swap buffers without a current OpenGL or OpenGL ES context");
+    return;
+  }
+
+  glFlush();
+
+  auto const result = emscripten_webgl_commit_frame();
+  if(result != EMSCRIPTEN_RESULT_SUCCESS &&
+     result != EMSCRIPTEN_RESULT_DEFERRED &&
+     result != EMSCRIPTEN_RESULT_INVALID_TARGET)
+  {
+    ErrorHandler::instance().logError(GLFW_PLATFORM_ERROR, "Failed to commit WebGL frame [%d]", result);
+  }
+}
