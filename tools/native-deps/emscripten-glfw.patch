+//------------------------------------------------------------------------
+// Context::getVideoModes
+//------------------------------------------------------------------------
+const GLFWvidmode* Context::getVideoModes(GLFWmonitor* iMonitor, int* oCount)
+{
+  auto monitor = getMonitor(iMonitor);
+  if(monitor)
+  {
+    auto modes = monitor->getVideoModes();
+    *oCount = monitor->getVideoModeCount();
+    return monitor->getVideoModesPtr();
+  }
+  *oCount = 0;
+  return nullptr;
+}
+
+//------------------------------------------------------------------------
+// Context::getVideoMode
+//------------------------------------------------------------------------
+const GLFWvidmode* Context::getVideoMode(GLFWmonitor* iMonitor)
+{
+  auto monitor = getMonitor(iMonitor);
+  if(monitor && monitor->getVideoModeCount() > 0)
+  {
+    return &monitor->getVideoModes()[0];
+  }
+  return nullptr;
+}
+
+//------------------------------------------------------------------------
+// Context::initializeVideoModes
+//------------------------------------------------------------------------
+void Context::initializeVideoModes()
+{
+  int width, height;
+  emscripten_get_screen_size(&width, &height);
+
+  // Create a single video mode with screen dimensions
+  // 1 byte (8 bits) for each RGBA channel
+  // 60Hz refresh rate
+  GLFWvidmode mode{
+    .width = width,
+    .height = height,
+    .redBits = 8,
+    .greenBits = 8,
+    .blueBits = 8,
+    .refreshRate = 60
+  };
+
+  fCurrentMonitor->addVideoMode(mode);
+}
